#!/bin/bash
set -euo pipefail

# FileGuard — CLI для защиты чувствительных файлов и мониторинга процессов
# Все файлы принадлежат root:wheel с chmod 600
# Разблокировка только через диалог подтверждения

GUARD_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || readlink "$0" 2>/dev/null || echo "$0")")" && pwd)"
CONFIG_FILE="$GUARD_DIR/config"
LOG_FILE="$GUARD_DIR/logs/access.log"
INTEGRITY_FILE="$GUARD_DIR/integrity.sha256"
LOCK_TIMEOUT=300  # 5 минут
CURRENT_USER="$(logname 2>/dev/null || echo "$USER")"
HOME_DIR="$(eval echo ~"$CURRENT_USER")"

# ─── Цвета ───
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# ─── Логирование ───
log_event() {
    local level="$1" message="$2"
    echo "$(date '+%Y-%m-%d %H:%M:%S') [$level] $message" >> "$LOG_FILE" 2>/dev/null || true
}

# ─── Integrity Check ───
verify_integrity() {
    if [[ ! -f "$INTEGRITY_FILE" ]]; then
        return 0  # первый запуск, хешей ещё нет
    fi

    local failed=0
    while IFS='  ' read -r expected_hash file_path; do
        [[ "$expected_hash" =~ ^#.*$ || -z "$expected_hash" ]] && continue
        if [[ -f "$file_path" ]]; then
            local actual_hash
            actual_hash=$(shasum -a 256 "$file_path" | awk '{print $1}')
            if [[ "$actual_hash" != "$expected_hash" ]]; then
                failed=1
                echo -e "${RED}ALARM: Целостность нарушена: $file_path${NC}"
                log_event "ALARM" "Integrity check FAILED for $file_path (expected: $expected_hash, got: $actual_hash)"
            fi
        fi
    done < "$INTEGRITY_FILE"

    if [[ $failed -eq 1 ]]; then
        osascript -e 'display dialog "⛔ GUARD INTEGRITY ALARM!\n\nСкрипты guard были изменены!\nВозможна подмена малварью.\n\nНе используйте guard до проверки." buttons {"OK"} default button "OK" with icon stop with title "FileGuard ALARM"' 2>/dev/null || true
        echo -e "${RED}GUARD ОСТАНОВЛЕН. Проверьте скрипты вручную.${NC}"
        exit 1
    fi
}

# ─── Генерация хешей ───
generate_integrity() {
    local scripts=("$GUARD_DIR/guard" "$GUARD_DIR/fileguard-daemon.sh" "$GUARD_DIR/procguard-daemon.sh")

    # Снять schg флаг если установлен
    chflags noschg "$INTEGRITY_FILE" 2>/dev/null || true

    : > "$INTEGRITY_FILE"
    for script in "${scripts[@]}"; do
        if [[ -f "$script" ]]; then
            shasum -a 256 "$script" >> "$INTEGRITY_FILE"
        fi
    done

    chown root:wheel "$INTEGRITY_FILE"
    chmod 644 "$INTEGRITY_FILE"
    chflags schg "$INTEGRITY_FILE"

    echo -e "${GREEN}Integrity хеши обновлены и защищены (schg)${NC}"
    log_event "INFO" "Integrity hashes regenerated"
}

# ─── Расширение путей из конфига ───
get_paths_for_category() {
    local category="$1"
    local paths=()

    while IFS='|' read -r cat path; do
        [[ "$cat" =~ ^#.*$ || -z "$cat" ]] && continue
        cat=$(echo "$cat" | xargs)
        path=$(echo "$path" | xargs)

        if [[ "$category" == "all" || "$cat" == "$category" ]]; then
            # Заменить ~ на реальный HOME
            path="${path/#\~/$HOME_DIR}"
            # Развернуть glob
            local expanded
            expanded=$(compgen -G "$path" 2>/dev/null || true)
            if [[ -n "$expanded" ]]; then
                while IFS= read -r p; do
                    paths+=("$p")
                done <<< "$expanded"
            fi
        fi
    done < "$CONFIG_FILE"

    if [[ ${#paths[@]} -gt 0 ]]; then
        printf '%s\n' "${paths[@]}"
    fi
}

# ─── Диалог подтверждения ───
ask_confirmation() {
    local message="$1"
    local result
    result=$(osascript -e "display dialog \"$message\" buttons {\"Deny\", \"Allow 5 min\"} default button \"Deny\" with icon caution with title \"FileGuard\"" 2>/dev/null) || true

    if [[ "$result" == *"Allow"* ]]; then
        return 0
    else
        return 1
    fi
}

# ─── Команда: init ───
cmd_init() {
    echo -e "${BLUE}FileGuard — инициализация защиты${NC}"
    echo ""

    if [[ $EUID -ne 0 ]]; then
        echo -e "${RED}Требуется sudo. Запустите: sudo guard init${NC}"
        exit 1
    fi

    local count=0
    local categories=("ssh" "env" "aws" "kube" "gpg" "keychain" "browser" "wallets")

    for cat in "${categories[@]}"; do
        local paths
        paths=$(get_paths_for_category "$cat")
        [[ -z "$paths" ]] && continue

        echo -e "${YELLOW}[$cat]${NC}"
        while IFS= read -r filepath; do
            [[ -z "$filepath" || ! -e "$filepath" ]] && continue

            # Пропустить директории, защищаем только файлы
            if [[ -d "$filepath" ]]; then
                # Для директорий — защитить содержимое
                find "$filepath" -type f 2>/dev/null | while IFS= read -r f; do
                    chown root:wheel "$f"
                    chmod 600 "$f"
                    echo "  🔒 $f"
                    ((count++)) || true
                done
            else
                chown root:wheel "$filepath"
                chmod 600 "$filepath"
                echo "  🔒 $filepath"
                ((count++)) || true
            fi
        done <<< "$paths"
    done

    echo ""
    echo -e "${GREEN}Защищено файлов: $count${NC}"

    # Генерация integrity хешей
    generate_integrity

    log_event "INFO" "guard init completed, $count files protected"
    echo -e "${GREEN}FileGuard инициализирован.${NC}"
}

# ─── Разблокировка файлов (общая функция) ───
do_unlock_files() {
    local paths="$1"
    while IFS= read -r filepath; do
        [[ -z "$filepath" || ! -e "$filepath" ]] && continue
        if [[ -d "$filepath" ]]; then
            find "$filepath" -type f 2>/dev/null | while IFS= read -r f; do
                chown "$CURRENT_USER:staff" "$f"
                chmod 600 "$f"
            done
        else
            chown "$CURRENT_USER:staff" "$filepath"
            chmod 600 "$filepath"
        fi
    done <<< "$paths"
}

# ─── Блокировка файлов (общая функция) ───
do_lock_files() {
    local paths="$1"
    while IFS= read -r filepath; do
        [[ -z "$filepath" || ! -e "$filepath" ]] && continue
        if [[ -d "$filepath" ]]; then
            find "$filepath" -type f 2>/dev/null | while IFS= read -r f; do
                chown root:wheel "$f"
                chmod 600 "$f"
            done
        else
            chown root:wheel "$filepath"
            chmod 600 "$filepath"
        fi
    done <<< "$paths"
}

# ─── Команда: unlock ───
cmd_unlock() {
    local category="${1:-}"
    local extra_path="${2:-}"
    local mode="timer"  # timer | session | manual

    # Парсинг флагов
    for arg in "$@"; do
        case "$arg" in
            --session) mode="session" ;;
            --manual)  mode="manual" ;;
        esac
    done
    # Убрать флаги из category/extra_path
    category="${category#--*}"
    [[ "$category" == "session" || "$category" == "manual" ]] && category="${2:-}" && extra_path="${3:-}"

    if [[ -z "$category" ]]; then
        echo "Использование: guard unlock <category> [path] [--session|--manual]"
        echo "Категории: ssh, env, aws, kube, gpg, keychain, browser, wallets, all"
        echo ""
        echo "Режимы:"
        echo "  (по умолчанию)  Авто-блокировка через 5 минут"
        echo "  --session       Держать пока есть активные SSH-сессии"
        echo "  --manual        Держать до ручного guard lock"
        exit 1
    fi

    if [[ $EUID -ne 0 ]]; then
        echo -e "${YELLOW}Требуется sudo для разблокировки.${NC}"
        exec sudo "$0" unlock "$@"
    fi

    # Integrity check
    verify_integrity

    local paths
    if [[ -n "$extra_path" && "$category" == "env" ]]; then
        paths=$(find "$extra_path" -maxdepth 2 -name '.env*' -o -name 'production.yml' -o -name 'credentials.yml' 2>/dev/null || true)
    else
        paths=$(get_paths_for_category "$category")
    fi

    if [[ -z "$paths" ]]; then
        echo -e "${YELLOW}Нет файлов в категории '$category'${NC}"
        exit 0
    fi

    # Текст диалога зависит от режима
    local dialog_msg file_count
    file_count=$(echo "$paths" | wc -l | xargs)

    case "$mode" in
        timer)   dialog_msg="Разблокировать $category ($file_count файлов) на 5 минут?" ;;
        session) dialog_msg="Разблокировать $category ($file_count файлов) до конца SSH-сессии?" ;;
        manual)  dialog_msg="Разблокировать $category ($file_count файлов) до ручной блокировки?" ;;
    esac

    if ! ask_confirmation "$dialog_msg"; then
        echo -e "${RED}Отклонено пользователем.${NC}"
        log_event "DENY" "unlock $category denied by user (mode: $mode)"
        exit 0
    fi

    # Разблокировка
    do_unlock_files "$paths"

    case "$mode" in
        timer)
            echo -e "${GREEN}$category разблокирован на 5 минут.${NC}"
            log_event "ALLOW" "unlock $category for $CURRENT_USER (mode: timer, timeout: ${LOCK_TIMEOUT}s)"
            # Авто-блокировка через 5 минут
            (
                sleep "$LOCK_TIMEOUT"
                do_lock_files "$paths"
                log_event "AUTO" "auto-lock $category after timeout"
                osascript -e 'display notification "'"$category"' заблокирован (таймаут)" with title "FileGuard"' 2>/dev/null || true
            ) &
            disown
            ;;

        session)
            echo -e "${GREEN}$category разблокирован до конца SSH-сессии.${NC}"
            echo -e "${YELLOW}Мониторю SSH-соединения... Заблокирую когда все закроются.${NC}"
            log_event "ALLOW" "unlock $category for $CURRENT_USER (mode: session)"
            # Мониторинг SSH-сессий в фоне
            (
                # Ждём пока появится хотя бы одна SSH-сессия (макс 60 сек)
                local waited=0
                while [[ $waited -lt 60 ]]; do
                    if pgrep -f "^ssh " >/dev/null 2>&1; then
                        break
                    fi
                    sleep 2
                    ((waited+=2))
                done

                # Ждём пока все SSH-сессии завершатся
                while pgrep -f "^ssh " >/dev/null 2>&1; do
                    sleep 5
                done

                # Все SSH-сессии закрыты — блокируем
                do_lock_files "$paths"
                log_event "AUTO" "auto-lock $category (SSH sessions ended)"
                osascript -e 'display notification "'"$category"' заблокирован (SSH-сессии завершены)" with title "FileGuard"' 2>/dev/null || true
            ) &
            disown
            ;;

        manual)
            echo -e "${GREEN}$category разблокирован до ручной блокировки.${NC}"
            echo -e "${YELLOW}Не забудь: guard lock $category${NC}"
            log_event "ALLOW" "unlock $category for $CURRENT_USER (mode: manual)"
            ;;
    esac
}

# ─── Команда: lock ───
cmd_lock() {
    local category="${1:-all}"

    if [[ $EUID -ne 0 ]]; then
        exec sudo "$0" lock "$category"
    fi

    local paths
    paths=$(get_paths_for_category "$category")

    if [[ -z "$paths" ]]; then
        echo -e "${YELLOW}Нет файлов для блокировки.${NC}"
        exit 0
    fi

    do_lock_files "$paths"

    echo -e "${GREEN}$category заблокирован.${NC}"
    log_event "LOCK" "locked $category"
}

# ─── Команда: status ───
cmd_status() {
    verify_integrity

    echo -e "${BLUE}FileGuard — статус${NC}"
    echo ""

    local categories=("ssh" "env" "aws" "kube" "gpg" "keychain" "browser" "wallets")

    for cat in "${categories[@]}"; do
        local paths locked=0 unlocked=0 missing=0
        paths=$(get_paths_for_category "$cat")
        [[ -z "$paths" ]] && continue

        while IFS= read -r filepath; do
            [[ -z "$filepath" ]] && continue
            if [[ ! -e "$filepath" ]]; then
                ((missing++)) || true
                continue
            fi
            local owner
            owner=$(stat -f '%Su' "$filepath" 2>/dev/null || echo "unknown")
            if [[ "$owner" == "root" ]]; then
                ((locked++)) || true
            else
                ((unlocked++)) || true
            fi
        done <<< "$paths"

        local status_icon
        if [[ $unlocked -gt 0 ]]; then
            status_icon="${RED}UNLOCKED${NC}"
        elif [[ $locked -gt 0 ]]; then
            status_icon="${GREEN}LOCKED${NC}"
        else
            status_icon="${YELLOW}NO FILES${NC}"
        fi

        printf "  %-12s %b  (locked: %d, unlocked: %d, missing: %d)\n" \
            "[$cat]" "$status_icon" "$locked" "$unlocked" "$missing"
    done

    echo ""

    # Проверка SIP
    local sip_status
    sip_status=$(csrutil status 2>/dev/null || echo "unknown")
    if [[ "$sip_status" == *"enabled"* ]]; then
        echo -e "  SIP:         ${GREEN}enabled${NC}"
    else
        echo -e "  SIP:         ${RED}DISABLED — включите SIP!${NC}"
    fi

    # Проверка демонов
    if pgrep -f "fileguard-daemon" >/dev/null 2>&1; then
        echo -e "  FileGuard:   ${GREEN}running${NC}"
    else
        echo -e "  FileGuard:   ${YELLOW}not running${NC}"
    fi

    if pgrep -f "procguard-daemon" >/dev/null 2>&1; then
        echo -e "  ProcessGuard: ${GREEN}running${NC}"
    else
        echo -e "  ProcessGuard: ${YELLOW}not running${NC}"
    fi

    # Быстрая проверка Claude Code permissions
    local claude_settings="$HOME_DIR/.claude/settings.json"
    if [[ -f "$claude_settings" ]]; then
        if grep -qF 'Bash(*)' "$claude_settings" 2>/dev/null; then
            echo -e "  Claude Code: ${RED}DANGER — Bash(*) разрешён!${NC}"
        elif grep -qE '"(allowedTools|allow)"' "$claude_settings" 2>/dev/null; then
            echo -e "  Claude Code: ${YELLOW}есть allowedTools (запусти guard audit)${NC}"
        else
            echo -e "  Claude Code: ${GREEN}permissions OK${NC}"
        fi
    fi
}

# ─── Команда: log ───
cmd_log() {
    if [[ -f "$LOG_FILE" ]]; then
        tail -50 "$LOG_FILE"
    else
        echo "Лог пуст."
    fi
}

# ─── Команда: add ───
cmd_add() {
    local filepath="${1:-}"
    local category="${2:-custom}"

    if [[ -z "$filepath" ]]; then
        echo "Использование: guard add /path/to/file [category]"
        exit 1
    fi

    filepath=$(realpath "$filepath" 2>/dev/null || echo "$filepath")

    # Заменить HOME на ~
    local config_path="${filepath/$HOME_DIR/\~}"
    echo "$category|$config_path" >> "$CONFIG_FILE"
    echo -e "${GREEN}Добавлено: $config_path (категория: $category)${NC}"

    # Если есть sudo — сразу заблокировать
    if [[ $EUID -eq 0 ]]; then
        chown root:wheel "$filepath"
        chmod 600 "$filepath"
        echo -e "${GREEN}Файл заблокирован.${NC}"
    else
        echo -e "${YELLOW}Запустите 'sudo guard lock $category' для блокировки.${NC}"
    fi

    log_event "ADD" "added $filepath to category $category"
}

# ─── Команда: remove ───
cmd_remove() {
    local filepath="${1:-}"

    if [[ -z "$filepath" ]]; then
        echo "Использование: guard remove /path/to/file"
        exit 1
    fi

    filepath=$(realpath "$filepath" 2>/dev/null || echo "$filepath")
    local config_path="${filepath/$HOME_DIR/\~}"

    # Удалить из конфига
    local tmp
    tmp=$(mktemp)
    grep -v "|${config_path}$" "$CONFIG_FILE" > "$tmp" || true
    mv "$tmp" "$CONFIG_FILE"

    # Вернуть ownership пользователю
    if [[ $EUID -eq 0 && -e "$filepath" ]]; then
        chown "$CURRENT_USER:staff" "$filepath"
        chmod 600 "$filepath"
    fi

    echo -e "${GREEN}Удалено из защиты: $config_path${NC}"
    log_event "REMOVE" "removed $filepath from protection"
}

# ─── Команда: verify ───
cmd_verify() {
    echo -e "${BLUE}FileGuard — проверка целостности${NC}"
    verify_integrity
    echo -e "${GREEN}Все проверки пройдены.${NC}"
}

# ─── Команда: scan ───
cmd_scan() {
    local target="${1:-.}"
    "$GUARD_DIR/codescan.sh" scan "$target"
}

# ─── Команда: audit (проверка конфигов Claude Code) ───
cmd_audit() {
    echo -e "${BLUE}FileGuard — аудит конфигов AI-ассистентов${NC}"
    echo ""

    local alerts=0
    local critical=0

    # ─── Опасные wildcard-разрешения ───
    # Bash(*) = ассистент может выполнить ЛЮБУЮ команду без подтверждения
    # Edit(*) / Write(*) = может изменить любой файл на диске
    local DANGEROUS_WILDCARDS=(
        "Bash(\*)"
        "Edit(\*)"
        "Write(\*)"
        "Bash(sudo"
    )

    # ─── Опасные конкретные разрешения ───
    # Даже без wildcard, определённые команды не должны быть авто-одобрены
    local DANGEROUS_COMMANDS=(
        "Bash(rm "
        "Bash(curl "
        "Bash(wget "
        "Bash(chmod "
        "Bash(chown "
        "Bash(mv "
        "Bash(cp "
        "Bash(dd "
        "Bash(mkfs"
        "Bash(kill "
        "Bash(pkill "
        "Bash(launchctl "
        "Bash(defaults write"
        "Bash(osascript"
        "Bash(security "
        "Bash(ssh "
        "Bash(scp "
        "Bash(rsync "
        "Bash(git push"
        "Bash(git reset"
        "Bash(npm publish"
        "Bash(npx "
        "Bash(pip install"
        "Bash(brew install"
        "Bash(open "
        "Bash(networksetup"
        "Bash(dscl "
        "Bash(crontab"
    )

    # ─── Все локации конфигов Claude Code ───
    local config_files=()

    # Глобальный settings
    [[ -f "$HOME_DIR/.claude/settings.json" ]] && config_files+=("$HOME_DIR/.claude/settings.json")

    # Проектные settings (могут быть подброшены в репо!)
    while IFS= read -r pfile; do
        [[ -n "$pfile" ]] && config_files+=("$pfile")
    done < <(find "$HOME_DIR/work" "$HOME_DIR/projects" "$HOME_DIR/Developer" -maxdepth 4 \( -path "*/.claude/settings.json" -o -path "*/.claude/settings.local.json" \) 2>/dev/null || true)

    # Также проверить текущую директорию
    [[ -f ".claude/settings.json" ]] && config_files+=("$(pwd)/.claude/settings.json")
    [[ -f ".claude/settings.local.json" ]] && config_files+=("$(pwd)/.claude/settings.local.json")

    if [[ ${#config_files[@]} -eq 0 ]]; then
        echo -e "${GREEN}Конфиги Claude Code не найдены.${NC}"
        return 0
    fi

    # ─── Проверка каждого конфига ───
    for config_path in "${config_files[@]}"; do
        local content
        content=$(cat "$config_path" 2>/dev/null) || continue

        local file_alerts=0
        local is_project_config=0

        # Проектный конфиг внутри репозитория — сам по себе подозрителен
        if [[ "$config_path" != "$HOME_DIR/.claude/settings.json" && "$config_path" != "$HOME_DIR/.claude.json" ]]; then
            is_project_config=1
        fi

        echo -e "${YELLOW}─── $config_path ───${NC}"

        # 1. Проверка allowedTools / permissions.allow на wildcard
        for wc in "${DANGEROUS_WILDCARDS[@]}"; do
            if echo "$content" | grep -qF "$(echo "$wc" | sed 's/\\//g')"; then
                ((critical++))
                ((file_alerts++))
                local clean_wc
                clean_wc=$(echo "$wc" | sed 's/\\//g')
                echo -e "  ${RED}!!!  КРИТИЧЕСКОЕ: разрешение $clean_wc${NC}"
                echo -e "  ${RED}     Ассистент может выполнять ЛЮБЫЕ действия этого типа без подтверждения!${NC}"
                log_event "AUDIT_CRITICAL" "Claude config $config_path: dangerous wildcard $clean_wc"
            fi
        done

        # 2. Проверка опасных конкретных команд
        for cmd in "${DANGEROUS_COMMANDS[@]}"; do
            if echo "$content" | grep -qF "$cmd"; then
                ((alerts++))
                ((file_alerts++))
                echo -e "  ${YELLOW}  ⚠ Опасное разрешение: $cmd...${NC}"
                echo -e "  ${YELLOW}    Эта команда может нанести ущерб без подтверждения${NC}"
                log_event "AUDIT_WARN" "Claude config $config_path: dangerous command $cmd"
            fi
        done

        # 3. Проверка MCP-серверов (только в settings.json, не в рантайм-файлах)
        if echo "$content" | grep -qF '"mcpServers"'; then
            # Извлечь имена серверов из блока mcpServers
            local in_mcp=0
            local mcp_names=""
            while IFS= read -r json_line; do
                if echo "$json_line" | grep -qF '"mcpServers"'; then
                    in_mcp=1
                    continue
                fi
                if [[ $in_mcp -eq 1 ]]; then
                    # Выход из блока mcpServers при закрывающей }
                    local server_name
                    server_name=$(echo "$json_line" | grep -oE '"[a-zA-Z0-9_-]+"' | head -1 | tr -d '"')
                    if [[ -n "$server_name" && "$server_name" != "command" && "$server_name" != "args" && "$server_name" != "env" ]]; then
                        mcp_names="${mcp_names}${server_name}\n"
                    fi
                fi
            done <<< "$content"

            if [[ -n "$mcp_names" ]]; then
                ((alerts++))
                ((file_alerts++))
                echo -e "  ${YELLOW}  ⚠ Настроены MCP-серверы:${NC}"
                echo -e "$mcp_names" | sort -u | while IFS= read -r name; do
                    [[ -n "$name" ]] && echo -e "    ${YELLOW}- $name${NC}"
                done
                echo -e "  ${YELLOW}    MCP-серверы могут выполнять код от имени пользователя. Проверь каждый.${NC}"
            fi
        fi

        # 4. Проектный конфиг — предупреждение об атаке через репозиторий
        if [[ $is_project_config -eq 1 ]]; then
            # Проверить есть ли в нём permissions/allowedTools вообще
            if echo "$content" | grep -qE '"(allowedTools|permissions|allow)"'; then
                ((critical++))
                ((file_alerts++))
                echo -e "  ${RED}!!!  ПРОЕКТНЫЙ КОНФИГ СОДЕРЖИТ РАЗРЕШЕНИЯ!${NC}"
                echo -e "  ${RED}     Файл внутри репозитория задаёт permissions — возможна атака!${NC}"
                echo -e "  ${RED}     Злоумышленник мог подбросить этот файл через PR/commit.${NC}"
                echo ""
                echo -e "  ${RED}     Проверь git blame:${NC}"
                echo -e "  ${RED}     git -C $(dirname "$(dirname "$config_path")") log --oneline -- .claude/settings.json${NC}"
                log_event "AUDIT_CRITICAL" "Project config with permissions: $config_path"
            fi

            # Проверить есть ли hooks в проектном конфиге
            if echo "$content" | grep -qE '"hooks"'; then
                ((critical++))
                ((file_alerts++))
                echo -e "  ${RED}!!!  ПРОЕКТНЫЙ КОНФИГ СОДЕРЖИТ HOOKS!${NC}"
                echo -e "  ${RED}     Hooks выполняют shell-команды автоматически.${NC}"
                echo -e "  ${RED}     Это может быть вектор атаки через репозиторий!${NC}"
                log_event "AUDIT_CRITICAL" "Project config with hooks: $config_path"
            fi
        fi

        # 5. Проверка на подозрительные env переменные в MCP конфигах
        if echo "$content" | grep -qEi '(API_KEY|SECRET|TOKEN|PASSWORD|PRIVATE)'; then
            ((alerts++))
            ((file_alerts++))
            echo -e "  ${YELLOW}  ⚠ Конфиг может содержать секреты (ключи/токены)${NC}"
            echo -e "  ${YELLOW}    Убедись что файл не попадёт в git!${NC}"
            log_event "AUDIT_WARN" "Claude config may contain secrets: $config_path"
        fi

        if [[ $file_alerts -eq 0 ]]; then
            echo -e "  ${GREEN}Чисто.${NC}"
        fi
        echo ""
    done

    # ─── Проверка CLAUDE.md файлов в проектах ───
    echo -e "${YELLOW}─── Проверка CLAUDE.md ───${NC}"
    local claude_md_alerts=0
    while IFS= read -r md_file; do
        [[ -z "$md_file" ]] && continue
        local md_content
        md_content=$(cat "$md_file" 2>/dev/null) || continue

        # CLAUDE.md не должен содержать инструкции на скачивание/выполнение
        if echo "$md_content" | grep -qEi '(curl|wget|bash -c|sh -c|eval|exec|npm run|npx )\s'; then
            ((alerts++))
            ((claude_md_alerts++))
            echo -e "  ${YELLOW}  ⚠ $md_file содержит команды выполнения${NC}"
            echo "$md_content" | grep -nEi '(curl|wget|bash -c|sh -c|eval|exec)' | head -3 | while IFS= read -r line; do
                echo -e "    ${YELLOW}> $line${NC}"
            done
        fi
    done < <(find "$HOME_DIR/work" "$HOME_DIR/projects" "$HOME_DIR/Developer" -maxdepth 3 -name "CLAUDE.md" 2>/dev/null || true)

    if [[ $claude_md_alerts -eq 0 ]]; then
        echo -e "  ${GREEN}Чисто.${NC}"
    fi
    echo ""

    # ─── Итог ───
    echo ""
    if [[ $critical -gt 0 ]]; then
        echo -e "${RED}╔══════════════════════════════════════════════════════════╗${NC}"
        echo -e "${RED}║  НАЙДЕНО $critical КРИТИЧЕСКИХ ПРОБЛЕМ В КОНФИГАХ!              ║${NC}"
        echo -e "${RED}║  AI-ассистент имеет слишком широкие разрешения!         ║${NC}"
        echo -e "${RED}║                                                         ║${NC}"
        echo -e "${RED}║  Рекомендация: удали wildcard-разрешения и настрой      ║${NC}"
        echo -e "${RED}║  точечные permissions для каждого проекта отдельно.     ║${NC}"
        echo -e "${RED}╚══════════════════════════════════════════════════════════╝${NC}"
        log_event "AUDIT" "COMPLETED: $critical critical, $alerts total issues"

        osascript -e "display dialog \"Guard Audit: НАЙДЕНО $critical КРИТИЧЕСКИХ ПРОБЛЕМ!\n\nAI-ассистент имеет слишком широкие разрешения.\nСмотри терминал для деталей.\" buttons {\"OK\"} default button \"OK\" with icon stop with title \"Guard Audit\"" 2>/dev/null || true
        return 1

    elif [[ $alerts -gt 0 ]]; then
        echo -e "${YELLOW}[Audit] Найдено $alerts предупреждений. Проверь вручную.${NC}"
        log_event "AUDIT" "COMPLETED: 0 critical, $alerts warnings"
        return 0

    else
        echo -e "${GREEN}[Audit] Чисто. Конфиги AI-ассистентов в порядке.${NC}"
        log_event "AUDIT" "COMPLETED: clean"
        return 0
    fi
}

# ─── Команда: update-integrity ───
cmd_update_integrity() {
    if [[ $EUID -ne 0 ]]; then
        exec sudo "$0" update-integrity
    fi
    generate_integrity
}

# ─── Команда: help ───
cmd_help() {
    echo -e "${BLUE}FileGuard — защита чувствительных файлов${NC}"
    echo ""
    echo "Команды:"
    echo "  guard init                    Инициализация (chown root + chmod 600)"
    echo "  guard unlock <category>       Разблокировать категорию на 5 мин"
    echo "  guard unlock ssh --session    Держать пока SSH-сессия активна"
    echo "  guard unlock ssh --manual     Держать до ручного guard lock"
    echo "  guard unlock env /path        Разблокировать .env в проекте"
    echo "  guard lock [category]         Заблокировать (по умолчанию: all)"
    echo "  guard status                  Показать статус"
    echo "  guard log                     Показать лог доступа"
    echo "  guard add /path [category]    Добавить файл под защиту"
    echo "  guard remove /path            Убрать файл из защиты"
    echo "  guard verify                  Проверить целостность скриптов"
    echo "  guard scan [path]             Сканировать код на малварь"
    echo "  guard audit                   Аудит конфигов AI-ассистентов (Claude Code)"
    echo "  guard update-integrity        Обновить хеши (после обновления скриптов)"
    echo ""
    echo "Категории: ssh, env, aws, kube, gpg, keychain, browser, wallets, all"
}

# ─── Main ───
command="${1:-help}"
shift || true

case "$command" in
    init)              cmd_init ;;
    unlock)            cmd_unlock "$@" ;;
    lock)              cmd_lock "$@" ;;
    status)            cmd_status ;;
    log)               cmd_log ;;
    add)               cmd_add "$@" ;;
    remove)            cmd_remove "$@" ;;
    scan)              cmd_scan "$@" ;;
    audit)             cmd_audit ;;
    verify)            cmd_verify ;;
    update-integrity)  cmd_update_integrity ;;
    help|--help|-h)    cmd_help ;;
    *)
        echo -e "${RED}Неизвестная команда: $command${NC}"
        cmd_help
        exit 1
        ;;
esac
